{
	"name": "vite-app-template",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"engines": {
		"node": ">=24.12.0",
		"pnpm": ">=10.13.1"
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"lint": "eslint . --fix && pnpm lint-i18n",
		"lint-i18n": "tsx src/utils/lint-i18n.ts",
		"test": "vitest",
		"test:watch": "vitest --watch",
		"test:cov": "vitest run --coverage",
		"test:ui": "vitest --ui",
		"storybook:dev": "storybook dev -p 6006",
		"storybook:build": "storybook build",
		"prepare": "lefthook install",
		"cy:open": "cypress open",
		"cy:run": "cypress run",
		"cy:run:allure": "cypress run --env allure=true",
		"allure:clean": "rimraf allure-results allure-report",
		"allure:generate": "allure generate allure-results -o allure-report",
		"allure:open": "allure open allure-report"
	},
	"dependencies": {
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-query-devtools": "^5.91.3",
		"axios": "^1.13.5",
		"date-fns": "^4.1.0",
		"i18next": "^25.8.13",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-i18next": "^16.5.4",
		"react-router": "^7.13.0",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^4.1.3",
		"@commitlint/cli": "^20.4.2",
		"@commitlint/config-conventional": "^20.4.2",
		"@eslint/js": "^9.39.3",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.6",
		"@semantic-release/npm": "^13.1.4",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"@storybook/addon-docs": "^10.2.10",
		"@storybook/addon-onboarding": "^10.2.10",
		"@storybook/builder-vite": "^10.2.10",
		"@storybook/react-vite": "^10.2.10",
		"@tailwindcss/vite": "^4.2.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react-swc": "^3.11.0",
		"@vitest/coverage-v8": "^3.2.4",
		"allure": "3.0.0",
		"allure-commandline": "2.36.0",
		"allure-cypress": "3.4.3",
		"cypress": "15.8.2",
		"eslint": "^9.39.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.26",
		"eslint-plugin-storybook": "9.0.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^16.5.0",
		"jsdom": "^26.1.0",
		"lefthook": "^1.13.6",
		"lint-staged": "^15.5.2",
		"prettier": "3.5.3",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"rimraf": "6.1.2",
		"storybook": "^9.1.19",
		"storybook-addon-pseudo-states": "^9.1.19",
		"tailwindcss": "^4.2.0",
		"tsx": "^4.21.0",
		"typescript": "~5.7.3",
		"typescript-eslint": "^8.56.0",
		"vite": "^6.4.1",
		"vite-plugin-svgr": "^4.5.0",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.2.4"
	},
	"packageManager": "pnpm@10.13.1"
}
