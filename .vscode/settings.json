{
	"cSpell.words": ["lefthook"],
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "explicit"
	},
	"editor.formatOnSave": true,
	"editor.defaultFormatter": "biomejs.biome",
	"editor.detectIndentation": false,
	"editor.guides.bracketPairs": "active",
	"editor.linkedEditing": true,
	"editor.renderControlCharacters": true,
	"editor.renderWhitespace": "all",
	"editor.tabSize": 4,
	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.patterns": {
		".editorconfig": "biome.json, lefthook*, commitlint*",
		".env": ".env*",
		".gitignore": ".git*",
		"package.json": "tsconfig*, pnpm*, .nvmrc, .releaserc, tailwind*, postcss*, next.config.ts, vite*"
	},
	"i18n-ally.keystyle": "flat",
	"i18n-ally.localesPaths": ["**/languages/**"],
	"i18n-ally.sourceLanguage": "en",
	"tailwindCSS.experimental.classRegex": [
		["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
		["cx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
	],
	"coverage-gutters.coverageFileNames": ["clover.xml"]
}
